<form class="critical-ruban-position-picker">
  <p>{{localize "critical-ruban.positionPicker.description"}}</p>

  <div class="form-group">
    <label>{{localize "critical-ruban.settings.useCustomPos.name"}}</label>
    <input name="isCustomPos" type="checkbox" {{#if data.isCustomPos}}checked{{/if}} />
  </div>
  
  <div class="form-group">
    <label>{{localize "critical-ruban.settings.useCustomPos.name"}}</label>
    <input name="bannerPosX" type="text" value="{{data.bannerPosX}}" />
  </div>
  
  <div class="form-group">
    <label>{{localize "critical-ruban.settings.useCustomPos.name"}}</label>
    <input name="bannerPosY" type="text" value="{{data.bannerPosY}}" />
  </div>

  <div class="form-group" style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
    <button type="button" data-action="pick">
      <i class="fas fa-crosshairs"></i>
      {{localize "critical-ruban.positionPicker.pickButton"}}
    </button>

    <button type="button" data-action="reset">
      <i class="fas fa-rotate-left"></i>
      {{localize "critical-ruban.positionPicker.resetButton"}}
    </button>
  </div>
</form>